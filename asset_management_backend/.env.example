# Backend environment variables (example)
#
# IMPORTANT:
# - Do not commit secrets into .env
# - Set DATABASE_URL to point at the asset_management_database Postgres instance.

# Preferred SQLAlchemy DB URL (driver included)
DATABASE_URL=postgresql+psycopg2://appuser:dbuser123@localhost:5000/myapp

# Alternative compatibility variable (also accepted)
POSTGRES_URL=postgresql://appuser:dbuser123@localhost:5000/myapp
