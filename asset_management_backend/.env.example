# Backend environment variables (example)
# Copy to .env and fill with real values.
#
# NOTE: Do not commit real secrets.

# Database (one of these is required)
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/asset_management
# POSTGRES_URL=postgresql://user:password@localhost:5432/asset_management

# JWT (required only if/when auth is enabled)
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File uploads
UPLOAD_DIR=./uploads
