{"is_source_file": true, "format": "Python", "description": "This file contains SQLAlchemy ORM model definitions for various entities within the Asset Health & Maintenance platform. It defines data models such as User, Asset, Inspection, Alert, WorkOrder, TimelineEvent, and related enumerations, relationships, and database indexes. The models are used for database schema representation and ORM operations in the backend application.", "external_files": ["api/db/session"], "external_methods": ["func.now()"], "published": ["User", "Asset", "Inspection", "InspectionPhoto", "Alert", "WorkOrder", "WorkOrderStatusHistory", "TimelineEvent", "UserRole", "AssetCriticality", "InspectionType", "AlertSeverity", "WorkOrderStatus", "TimelineEventType"], "classes": [{"name": "User", "description": "Represents user accounts, including authentication and authorization data. Supports relationships to inspections and work orders."}, {"name": "Asset", "description": "Represents assets being monitored in the system, including fields for criticality, location, and health scores. Related to inspections, alerts, work orders, and timeline events."}, {"name": "Inspection", "description": "Stores inspection records for assets, including type, notes, readings, and related photos. Linked to inspector user and asset."}, {"name": "InspectionPhoto", "description": "Stores references to photos associated with inspections, including file key and filename."}, {"name": "Alert", "description": "Represents alerts generated for assets based on health or conditions, with severity, description, and related work orders."}, {"name": "WorkOrder", "description": "Tracks work orders created for asset maintenance, including status, description, priority, and related user assignments."}, {"name": "WorkOrderStatusHistory", "description": "Maintains a history of status changes for work orders, supporting audit trails."}, {"name": "TimelineEvent", "description": "Provides a timeline of asset-related events such as in